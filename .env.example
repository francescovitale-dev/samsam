# ---- SamSam Offerte — environment variables ----
# Copy to `.env` and fill in. See README for provisioning notes.

# PostgreSQL (Vercel Postgres / Neon in prod; local Postgres in dev)
DATABASE_URL="postgresql://user:password@localhost:5432/samsam_offerte?schema=public"

# Single shared-password gate (internal tool — one user, no accounts, no email).
# APP_PASSWORD is what you type on the login screen.
# APP_GATE_TOKEN is a random secret cookie value — generate with: openssl rand -hex 24
APP_PASSWORD="change-me"
APP_GATE_TOKEN="generate-a-random-hex-string"

# Vercel Blob — file storage (uploaded photos, generated PDFs).
# Leave empty in dev: uploads fall back to /public/uploads on local disk.
BLOB_READ_WRITE_TOKEN=""

# PDF generation (headless Chromium).
# Optional managed-browser fallback if the serverless bundle is too large:
BROWSERLESS_URL=""
# Optional explicit local Chrome path for dev PDF rendering:
CHROME_EXECUTABLE_PATH=""

# Moneybird invoicing (phase 2) — feature-flagged off by default.
MONEYBIRD_ADMINISTRATION_ID=""
MONEYBIRD_API_TOKEN=""
FEATURE_MONEYBIRD="false"

# Public base URL (used where absolute links are needed).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
